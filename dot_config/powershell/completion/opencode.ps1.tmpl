{{ if lookPath "opencode" }}
# powershell completion for opencode
$RegisterTabArgumentCompleter = {
    param($wordToComplete, $commandAst, $cursorPosition)
    $choices = @(
        'completion', 'acp', 'mcp', 'attach', 'run', 'debug', 'providers', 'auth',
        'agent', 'upgrade', 'uninstall', 'serve', 'web', 'models', 'stats', 'export',
        'import', 'github', 'pr', 'session', 'plugin', 'plug', 'db',
        '-h', '--help',
        '-v', '--version',
        '--print-logs',
        '--log-level',
        '--pure',
        '--port',
        '--hostname',
        '--mdns',
        '--mdns-domain',
        '--cors',
        '-m', '--model',
        '-c', '--continue',
        '-s', '--session',
        '--fork',
        '--prompt',
        '--agent'
    )
    $choices | Where-Object { $_ -like "$wordToComplete*" } | ForEach-Object {
        [System.Management.Automation.CompletionResult]::new($_, $_, 'ParameterValue', $_)
    }
}
Register-ArgumentCompleter -CommandName 'opencode' -ScriptBlock $RegisterTabArgumentCompleter
{{ end }}
