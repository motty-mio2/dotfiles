{{ if eq .chezmoi.os "linux" -}}
{{ if or (lookPath "kanata") (lookPath "kanata_linux_x64") -}}
[Unit]
Description=Kanata Keymapper

[Service]
{{ if (lookPath "kanata") -}}
ExecStart={{ lookPath "kanata" }} --port 7070
{{ else if (lookPath "kanata_linux_x64") -}}
ExecStart={{ lookPath "kanata_linux_x64" }} --port 7070
{{ end -}}
ExecStop=/bin/kill ${MAINPID}
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
{{ end }}
{{ end }}
