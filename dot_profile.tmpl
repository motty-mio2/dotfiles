#!/usr/bin/env bash

# XDG CONFIG DIRS
{{- range $key, $value := .environment.xdg }}
export {{ $key }}="${{ $value }}"
{{- end }}
export XDG_RUNTIME_DIR="/run/user/$UID"

# APPLICATIONS PATH
{{- range $key, $value := .environment.application_path }}
export {{ $key }}="${{ $value }}"
{{- end }}
export XCURSOR_PATH="/usr/share/icons:$XDG_DATA_HOME/icons"
export COPILOT_OTEL_ENABLED=true
export COPILOT_OTEL_EXPORTER_TYPE="file"
export COPILOT_OTEL_FILE_EXPORTER_PATH="$HOME/.copilot/otel/copilot-otel-$(date +%Y%m%d-%H%M%S).jsonl"

# APPLICATIONS CONFIG
{{- range $key, $value := .environment.application_config }}
export {{ $key }}={{ $value }}
{{- end }}

export HISTFILE="$XDG_STATE_HOME/shell_history"
export HISTSIZE=10000
export SAVEHIST=10000

array=(
    "/usr/bin/lesspipe"
    "/usr/bin/lesspipe.sh"
)

for item in "${array[@]}"; do
    if [ -e "$item" ]; then
        export LESSOPEN="|$item %s"
        export LESSCLOSE="$item %s %s"
    fi
done

# PATH
export PATH="${{ .environment.path | join ":$"}}:$PATH"
export PATH="/opt/homebrew/bin:$PATH"
